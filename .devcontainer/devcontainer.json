{
    "name": "Sandbox",
    "image": "ghcr.io/fbottarel/ci_tests/devcontainer:latest",

    "build": {
        "dockerfile": "Dockerfile"   // fallback if image is not available
    },

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",         // IntelliSense, debugging
                "ms-vscode.cmake-tools",       // CMake integration
                "twxs.cmake",                  // CMake syntax highlighting
                "ms-python.python",            // Python IntelliSense, debugging
                "ms-python.vscode-pylance"     // Python language server
            ],
            "settings": {
                "cmake.buildDirectory": "${workspaceFolder}/cpp_sandbox/build",
                "cmake.sourceDirectory": "${workspaceFolder}/cpp_sandbox"
            }
        }
    },

    // Forward no ports by default — add here if you ever run a local server
    "forwardPorts": [],

    "postCreateCommand": "cmake -B cpp_sandbox/build -S cpp_sandbox && pip install -r python_sandbox/requirements.txt"
}